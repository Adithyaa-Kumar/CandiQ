# frontend/.env.example
# ───────────────────────
# Vite only reads .env files from the project root (frontend/), not from
# src/ — copy this to frontend/.env and fill in real values.

# Full base URL the browser calls for the API, INCLUDING the version
# prefix. axios uses this verbatim — if it's set, no proxy or extra path
# is added, so it must already be the complete path to /api/v1.
#
# Leave this unset for local dev without Docker: the client falls back to
# the relative path "/api/v1", and vite.config.js's dev-server proxy
# forwards that to the backend (default http://localhost:8000) for you.
VITE_API_BASE_URL=http://localhost:8000/api/v1
